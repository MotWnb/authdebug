{
	"schemaVersion": 1,
	"id": "authdebug",
	"version": "${version}",
	"name": "AuthDebug",
	"description": "A debug Mod for dealing with an unavailable authentication server",
	"authors": [
		"MotWnb"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "MIT",
	"icon": "assets/authdebug/icon.png",
	"environment": "*",
	"entrypoints": {
		"client": [
			"io.github.motwnb.authdebug.AuthDebug"
		]
	},
	"mixins": [
		{
			"config": "authdebug.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}